# =============================================================================
# Chat UI - OAuth Direct Mode
# =============================================================================

# LangGraph Server URL
NEXT_PUBLIC_API_URL=http://localhost:2024

# Auth Mode
AUTH_MODE=oauth-direct
NEXT_PUBLIC_AUTH_MODE=oauth-direct

# Google OAuth (for frontend token acquisition)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Note: In oauth-direct mode, no NextAuth database is needed.
# The LangGraph server validates OAuth tokens directly.
