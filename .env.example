# =============================================================================
# LangGraph Configuration
# =============================================================================
# LangGraph server URL
NEXT_PUBLIC_API_URL=http://localhost:2024
# Production:
# NEXT_PUBLIC_API_URL=https://my-agent.default.us.langgraph.app

# Default Graph ID (optional - users can select from the list if not set)
# NEXT_PUBLIC_ASSISTANT_ID=agent

# Server-side LangGraph URL (optional, for Docker internal network etc.)
# If not set, uses NEXT_PUBLIC_API_URL
# LANGGRAPH_API_URL=http://langgraph-api:8000

# LangSmith API Key (for tracing, separate from LangGraph auth)
LANGSMITH_API_KEY=lsv2_...

# =============================================================================
# Auth Configuration (NextAuth) - REQUIRED for authenticated mode
# =============================================================================
# Application URL (REQUIRED for production)
NEXTAUTH_URL=http://localhost:3000

# Secret key for JWT signing (REQUIRED)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=<generate with: openssl rand -base64 32>

# Trust Host (Optional - set in auth/config.ts by default)
# Set to true if running behind a reverse proxy or in Docker
# AUTH_TRUST_HOST=true

# Database URL
# Development (SQLite):
DATABASE_URL="file:./prisma/dev.db"
# Production (PostgreSQL):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
# Production (SQLite with absolute path):
# DATABASE_URL="file:/app/data/prod.db"

# =============================================================================
# Auth Mode Configuration
# =============================================================================
# AUTH_MODE: "public" (no login required) | "authenticated" (login required)
AUTH_MODE=authenticated

# REGISTRATION_POLICY: "open" (auto-approve) | "approval" (admin approval required)
REGISTRATION_POLICY=open

# Initial Admin: First user to register with this email becomes super_admin
# INITIAL_ADMIN_EMAIL=admin@example.com

# =============================================================================
# API Token Configuration (Optional)
# =============================================================================
# Default token expiration in days (0 = never expires)
# API_TOKEN_EXPIRATION_DAYS=0
