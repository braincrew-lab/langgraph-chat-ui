# =============================================================================
# LangGraph Configuration
# =============================================================================
# LangGraph server URL
NEXT_PUBLIC_API_URL=http://localhost:2024
# Production:
# NEXT_PUBLIC_API_URL=https://my-agent.default.us.langgraph.app

# Default Graph ID (optional - users can select from the list if not set)
# NEXT_PUBLIC_ASSISTANT_ID=agent

# Server-side LangGraph URL (optional, for Docker internal network etc.)
# If not set, uses NEXT_PUBLIC_API_URL
# LANGGRAPH_API_URL=http://langgraph-api:8000

# =============================================================================
# LangSmith Tracing (Optional)
# =============================================================================
# Enable tracing to monitor and debug your LangGraph agents
# Get your API key at: https://smith.langchain.com
# LANGSMITH_API_KEY=lsv2_pt_xxxxx
# LANGSMITH_PROJECT=my-project
# LANGSMITH_TRACING=true

# =============================================================================
# Auth Configuration (NextAuth) - REQUIRED for authenticated mode
# =============================================================================
# Application URL (REQUIRED for production)
NEXTAUTH_URL=http://localhost:3000

# Secret key for JWT signing (REQUIRED)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=<generate with: openssl rand -base64 32>

# Trust Host (Optional - set in auth/config.ts by default)
# Set to true if running behind a reverse proxy or in Docker
# AUTH_TRUST_HOST=true

# Database URL
# Development (SQLite):
DATABASE_URL="file:./prisma/dev.db"
# Production (PostgreSQL):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
# Production (SQLite with absolute path):
# DATABASE_URL="file:/app/data/prod.db"

# =============================================================================
# Auth Mode Configuration
# =============================================================================
# AUTH_MODE options:
#   - standalone    : No authentication (local/dev use)
#   - credentials   : Email/password login (default, requires DATABASE_URL)
#   - oauth         : OAuth providers (Google, GitHub, etc.)
#   - email         : Email magic link (passwordless)
#   - oauth-direct  : LangGraph server handles OAuth directly
#
# Legacy values (still supported):
#   - public        : Same as "standalone"
#   - authenticated : Same as "credentials"
#
AUTH_MODE=credentials
# Also set NEXT_PUBLIC_AUTH_MODE for client-side components
NEXT_PUBLIC_AUTH_MODE=credentials

# REGISTRATION_POLICY: "open" (auto-approve) | "approval" (admin approval required)
REGISTRATION_POLICY=open

# Initial Admin: First user to register with this email becomes super_admin
# INITIAL_ADMIN_EMAIL=admin@example.com

# =============================================================================
# OAuth Providers (Required for AUTH_MODE=oauth)
# =============================================================================
# Google OAuth
# Get credentials at: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# Get credentials at: https://github.com/settings/applications/new
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# Email Provider (Required for AUTH_MODE=email)
# =============================================================================
# SMTP server configuration for magic link emails
# EMAIL_SERVER_HOST=smtp.example.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=your-smtp-username
# EMAIL_SERVER_PASSWORD=your-smtp-password
# EMAIL_FROM=noreply@example.com

# =============================================================================
# API Token Configuration (Optional)
# =============================================================================
# Default token expiration in days (0 = never expires)
# API_TOKEN_EXPIRATION_DAYS=0
